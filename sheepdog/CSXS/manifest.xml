<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0"
                   ExtensionBundleId="com.sheepdog.premiere"
                   ExtensionBundleVersion="1.0.0"
                   ExtensionBundleName="SheepDog">

  <ExtensionList>
    <Extension Id="com.sheepdog.panel" Version="1.0.0" />
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- Premiere Pro: PPRO (not IDSN — IDSN is InDesign) -->
      <!-- Version 14.0 = Premiere Pro 2020, up to 99.9 for future compat -->
      <Host Name="PPRO" Version="[14.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="7.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.sheepdog.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>SheepDog</Menu>
          <Geometry>
            <Size>
              <Height>600</Height>
              <Width>400</Width>
            </Size>
            <MinSize>
              <Height>300</Height>
              <Width>280</Width>
            </MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>

</ExtensionManifest>
